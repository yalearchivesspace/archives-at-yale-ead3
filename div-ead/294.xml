      </prefercite>
      <bioghist id="aspace_ae7abf5c70c27dd7e8c5732afbecb0d6">
         <head>Biographical / Historical</head>
         <chronlist>
            <chronitem>
               <datesingle>1852 Mar 8</datesingle>
               <chronitemset>
                  <event>Born in New Haven, CT</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1874</datesingle>
               <chronitemset>
                  <event>B.A., Yale College</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1877</datesingle>
               <chronitemset>
                  <event>B.D., Yale Divinity School</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1879</datesingle>
               <chronitemset>
                  <event>Ordained as Congregational minister</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1878-1890</datesingle>
               <chronitemset>
                  <event>Served First Congregational Church in New Bedford, MA</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1890-1920</datesingle>
               <chronitemset>
                  <event>Served Orthodox Church (Pleasant Street Congregational) in Arlington, MA</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1917-1918</datesingle>
               <chronitemset>
                  <event>Alumni Lecturer, Yale Divinity School</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1920-1928</datesingle>
               <chronitemset>
                  <event>Resided in New Haven; preached at United Church; acting pastor there 1922-1923</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1928</datesingle>
               <chronitemset>
                  <event>Died</event>
               </chronitemset>
            </chronitem>
         </chronlist>
      </bioghist>
      <scopecontent id="aspace_f8f824f4470b77a25522b23dc2f35590">
         <head>Scope and Contents</head>
         <p>The collection consists almost entirely of manuscript sermons, arranged chronologically.</p>  
      </scopecontent>
