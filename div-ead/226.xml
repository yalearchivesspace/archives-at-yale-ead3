         <abstract id="aspace_1a4e6f21f33d7ce935b17ec04e5b2b08">This collection documents the history and operations of Campus Ministry Advancement, an organization incorporated in Ohio in 1967 to support Christian ministries in higher education. Legal documents, minutes, correspondence, financial records, and tax records are included.</abstract>
         <origination label="creator">
            <corpname source="local">
               <part>Campus Ministry Advancement</part>
            </corpname>
         </origination>
    
      </did>
