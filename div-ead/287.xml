         <head>Biographical / Historical</head>
         <chronlist>
            <chronitem>
               <datesingle>1889</datesingle>
               <chronitemset>
                  <event>Born in Wyoming, Ohio</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1912</datesingle>
               <chronitemset>
                  <event>B.A., Cornell University</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1915</datesingle>
               <chronitemset>
                  <event>B.D., Union Theological Seminary, New York</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1915-1919</datesingle>
               <chronitemset>
                  <event>Pastorate in Wallace, Texas</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1919-1920</datesingle>
               <chronitemset>
                  <event>Supervisor, Texas Church Survey</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1920-1923</datesingle>
               <chronitemset>
                  <event>Professor of Biblical History and Literature, Tusculum College, Tenn.</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1925</datesingle>
               <chronitemset>
                  <event>Ph.D., Yale University</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1925-1928</datesingle>
               <chronitemset>
                  <event>Assistant professor, Biblical Literature and History of Religion, Brown University</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1928-1932</datesingle>
               <chronitemset>
                  <event>Associate professor, Brown</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1932-1934</datesingle>
               <chronitemset>
                  <event>Professor, Brown</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1934-1948</datesingle>
               <chronitemset>
                  <event>President, American School for Oriental Research, Jersalem</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1934-1958</datesingle>
               <chronitemset>
                  <event>Winkley Professor of Biblical Theology, Yale Divinity School</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1950-1958</datesingle>
               <chronitemset>
                  <event>Chairman, Department of Near Eastern Languages and Literatures, Yale</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1960</datesingle>
               <chronitemset>
