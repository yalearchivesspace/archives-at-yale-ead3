         <abstract id="aspace_3371146e2cfa260cbe2a380361052631">The collection traces the operations of the Campus Ministry Women organization from its founding in 1974 until its disbanding in 1996.</abstract>
         <origination label="creator">
            <corpname identifier="dts_39c3bc7191186aa2cee1e1c1573f5f60c7bf9f02" source="naf">
