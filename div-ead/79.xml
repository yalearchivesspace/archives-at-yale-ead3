         <list listtype="unordered">
            <item>I. Writings by Colenso, 1855-1879, n.d.</item>
            <item>II. Writings about Colenso, 1856-1904, n.d.</item>
            <item>III. Writings by Colenso Family, 1907-1908</item>
            <item>IV. Photographs and Memorabilia, 1864-1882</item>
         </list>
      </arrangement>
