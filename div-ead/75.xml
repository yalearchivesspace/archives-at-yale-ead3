                  <event>Minister: Hanover Street Congregational Church, Milwaukee, Wisconsin</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1909-1914</datesingle>
               <chronitemset>
                  <event>Minister: First Congregational Church, Menasha, Wisconsin</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1914-1916</datesingle>
               <chronitemset>
                  <event>Superintendent: - Fox River Efficiency League</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1916-1918</datesingle>
               <chronitemset>
                  <event>Superintendent - Industrial League, Wisconsin Anti-Saloon League</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1918-1922</datesingle>
               <chronitemset>
                  <event>Minister: Park Congregational Church, Los Angeles, California</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1922-1927</datesingle>
               <chronitemset>
                  <event>Minister: First Congregational Church, Petaluma, California</event>
               </chronitemset>
            </chronitem>
            <chronitem>
