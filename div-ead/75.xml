         <head>Biographical / Historical</head>
         <chronlist>
      
            <chronitem>
               <datesingle>1858 Jan 29</datesingle>
               <chronitemset>
                  <event>Born in Canton, Ohio</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1882-1885</datesingle>
               <chronitemset>
                  <event>Attended Otterbein University</event>
               </chronitemset>
            </chronitem>
            <chronitem>
