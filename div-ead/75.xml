               <chronitemset>
                  <event>Ordained as United Brethren minister, Denver</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1889</datesingle>
               <chronitemset>
                  <event>B.D., Yale Divinity School</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1889-1895</datesingle>
               <chronitemset>
                  <event>Served under Washington Gladden as assistant minister of First Congregational Church, Columbus, Ohio; became first minister of Mayflower Congregational Church, formerly a mission chapel of Gladden's church.</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1895-1903</datesingle>
