                  <event>Trustee of the Congregational Church Building Committee</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1906</datesingle>
               <chronitemset>
                  <event>D.D., Parsons College</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1907</datesingle>
               <chronitemset>
                  <event>Died</event>
               </chronitemset>
            </chronitem>
         </chronlist>
