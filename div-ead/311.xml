               <chronitemset>
                  <event>B.D., Andover Theological Seminary</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1866</datesingle>
               <chronitemset>
                  <event>Appointed as missionary to Turkey but unable to serve due to poor health</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1869-1888</datesingle>
               <chronitemset>
                  <event>Minister of Congregational Church, Fairfield, Iowa</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1870</datesingle>
               <chronitemset>
                  <event>Married Helen Kirby</event>
               </chronitemset>
            </chronitem>
            <chronitem>
