         <head>Biographical / Historical</head>
         <chronlist>
            <chronitem>
               <datesingle>1841</datesingle>
               <chronitemset>
                  <event>Born in South Hadley, MA</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1860</datesingle>
               <chronitemset>
                  <event>Graduated from New York Free Academy</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1864</datesingle>
               <chronitemset>
                  <event>M.D., Bellevue Medical College</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1866</datesingle>
               <chronitemset>
                  <event>B.D., Andover Theological Seminary</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1866</datesingle>
               <chronitemset>
                  <event>Appointed as missionary to Turkey but unable to serve due to poor health</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1869-1888</datesingle>
               <chronitemset>
                  <event>Minister of Congregational Church, Fairfield, Iowa</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1870</datesingle>
               <chronitemset>
                  <event>Married Helen Kirby</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1904-1907</datesingle>
               <chronitemset>
                  <event>Recording Secretary of National Federation of Churches</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1906-1907</datesingle>
               <chronitemset>
                  <event>Trustee of the Congregational Church Building Committee</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1906</datesingle>
               <chronitemset>
                  <event>D.D., Parsons College</event>
               </chronitemset>
            </chronitem>
            <chronitem>
               <datesingle>1907</datesingle>
               <chronitemset>
                  <event>Died</event>
               </chronitemset>
            </chronitem>
         </chronlist>
      </bioghist>
      <scopecontent id="aspace_eb10febddcb54e64536b61b27bc1019d">
         <head>Scope and Contents</head>
         <list listtype="unordered">
            <item>
               <ref actuate="onrequest" show="replace" target="ref14">I. Biographical Information</ref>
            </item>
            <item>
               <ref actuate="onrequest" show="replace" target="ref17">II. Sermons</ref>
