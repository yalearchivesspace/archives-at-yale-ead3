               <fromdate standarddate="1925">1925</fromdate>
               <todate standarddate="1963">1963</todate>
            </daterange>
         </unitdatestructured>
         <abstract id="aspace_c85d51891fae8857dcdf20326d8e56fe">The collection consists of photographic negatives of new acquisitions, specifically acquisitions for the Rare Book Room (now the Beinecke Rare Book and Manuscript Library). Also included are photographs of exhibits, library staff at work, various library operations and departments, and bookplates, as well as a commemorative edition of the Yale Daily News featuring the opening of Sterling Memorial Library..</abstract>
    
      </did>
      <odd id="aspace_57efa105525c4f65df63ebc45f93a00f">
         <head>General note</head>
         <p>Forms part of Yale Record Group 32-A (YRG 32-A), Central records of the Yale University Library and records of the librarian.</p>  
      </odd>
      <accessrestrict id="aspace_d4971656b1e263a9b433cda11047a215">
         <head>Conditions Governing Access</head>
         <p>The materials are open for research.</p>  
      </accessrestrict>
      <prefercite id="aspace_820ec27ff51b3a604aafaa062cd11b1a">
         <head>Preferred Citation</head>
         <p>Yale University Library Photographs and Memorabilia of Collections and Events (RU 387). Manuscripts and Archives, Yale University Library.</p>  
      </prefercite>
      <arrangement id="aspace_bfabd06e3854a258969a7a68475c1154">
         <head>Arrangement</head>
         <p>The records are arranged by library department and by medium and in subsequent accessions.</p>  
      </arrangement>
      <scopecontent id="aspace_10de3df4fa31731410b3977e1685e8a8">
         <head>Scope and Contents</head>
         <p>The collection consists of photographic negatives of new acquisitions, specifically acquisitions for the Rare Book Room (now the Beinecke Rare Book and Manuscript Library). Also included are photographs of exhibits, library staff at work, various library operations and departments, and bookplates, as well as a commemorative edition of the <title render="italic">
               <part>Yale Daily News</part>
            </title> featuring the opening of Sterling Memorial Library.</p>  
      </scopecontent>
