      </acqinfo>
      <bioghist id="aspace_39cc271efa5c3bf179b7ba8a087fcbfb">
         <head>Biographical / Historical</head>
         <p>Rich Hanley is Associate Professor of Journalism at Quinnipiac University.  He is the director of the documentary <title render="italic">
               <part>Last Days of the Coliseum</part>
            </title>.</p>  
      </bioghist>
  
