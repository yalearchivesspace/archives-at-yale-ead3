         <head>Preferred Citation</head>
         <p>Richard Nash Gould Collection of Photographs Documenting Yale University (RU 1127). Manuscripts and Archives, Yale University Library.</p>  
      </prefercite>
      <arrangement id="aspace_42449913dfd3d93a0cb8c4d602b4a680">
