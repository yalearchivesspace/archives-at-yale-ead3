         <head>Preferred Citation</head>
         <p>Burundi Collection (MS 1506). Manuscripts and Archives, Yale University Library.</p>  
      </prefercite>
      <relatedmaterial id="aspace_e10060167c7ef9524fb62c5ce84d9fcf">
