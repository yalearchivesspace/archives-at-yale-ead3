               <c id="aspace_1a021db05236f8e4fbd0b62e13d58e04" level="file">
                  <did>
                     <unittitle>Spanish refugees on the French border postcards</unittitle>
                     <unitdate unitdatetype="inclusive">1939</unitdate>
                     <container altrender="archive legal"
                                containerid="39002104789558"
