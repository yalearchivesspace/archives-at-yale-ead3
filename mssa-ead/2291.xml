      <odd id="aspace_401a3ee282465ba183aeaa9fa059f975">
         <head>General note</head>
         <p>Forms part of Yale Record Group 3-D (YRG 3-D), Records documenting academic support functions at Yale.</p>  
      </odd>
      <acqinfo id="aspace_719cffeb243516e4d7256ed8264139d7">
