         <abstract id="aspace_65232cf819e265ee88ee403cb4ff9cf8">The records consist of scrapbooks, correspondence, scorecards, and reports documenting basketball at Yale.</abstract>
         <origination label="creator">
            <corpname rules="aacr" source="local">
