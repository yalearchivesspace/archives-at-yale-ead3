         <abstract id="aspace_2ed9b31d982f8e243c7c0e7d5313a750">An autograph collection of approximately forty letters and documents, chiefly dating from the Revolutionary War era. Prominent in the collection are Ashbel Green, James Wadsworth, and George Washington. Among the later writers are Albert Bierstadt, Richard Wagner and correspondents of Annie Burr Jennings.</abstract>
         <origination label="creator">
            <persname identifier="http://id.loc.gov/authorities/names/n2007160000"
                      relator="col"
                      rules="aacr"
                      source="naf">
               <part>Jennings, Annie Burr, 1855-1939</part>
            </persname>
         </origination>
    
      </did>
