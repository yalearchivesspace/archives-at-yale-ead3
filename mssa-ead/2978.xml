      </relatedmaterial>
      <acqinfo id="aspace_88224fbe6bb1bbfde336b7cea9a84410">
         <head>Immediate Source of Acquisition</head>
         <p>Gifts of George Vernadsky, Sergei Pushkarev, and Howard B. Gotlieb between 1957 and 1973.</p>
      </acqinfo>
      <accessrestrict id="aspace_4c959ff41c9b14f22fadc4d32ef96738">
