                      source="naf">
               <part>Hubbard, Charles D. (Charles Daniel), 1876-1951</part>
            </persname>
         </origination>
    
      </did>
      <odd id="aspace_1832fa64371037a7a7b5c2b432063a23">
         <head>General note</head>
         <p>Forms part of Yale Record Group 48-A (YRG 48-A), Yale pictorial records and collections.</p>  
      </odd>
