      </userestrict>
      <prefercite id="aspace_ac33bd5f50851af6c5c4eb72e73e7920">
         <head>Preferred Citation</head>
         <p>Bosnia and Herzegovina Political Ephemera Collection (MS 1926). Manuscripts and Archives, Yale University Library.</p>  
      </prefercite>
