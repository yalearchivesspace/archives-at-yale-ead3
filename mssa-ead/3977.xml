         </unitdatestructured>
         <abstract id="aspace_b6e067b8d6c36ab2936b66fdf93b7b62">A collection of letters and signed documents, chiefly of United States cabinet members and other government officials.</abstract>
         <origination label="Creator">
            <persname relator="col">
               <part localtype="agent_person">Metzdorf, Robert F. (Robert Frederic), 1912-</part>
            </persname>
         </origination>
