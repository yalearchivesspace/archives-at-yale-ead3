      <acqinfo id="aspace_a84db48688673bb2b581cf9383e8639b">
         <head>Immediate Source of Acquisition</head>
         <p>Transferred from Yale University Historical Medical Library, 1980; and gift of Norton Canfield, 1984.</p>  
      </acqinfo>
      <userestrict id="aspace_cff6845da2669c1f23ff97dad5b28c55">
