                 href="http://mssa.altfindingaids.library.yale.edu/mssa.ms.1431/mssa_ms_1431_genealogical_chart.pdf"
                 linktitle="Genealogical Chart"
                 show="new">Genealogical Chart</ref>.</p>  
      </bioghist>
  
