         <abstract id="aspace_30f1d0631292d924f5462c94eb1f62cb">Correspondence, volumes, and other papers collected by Rabinowitz. Includes autograph letters of Henry Blackwell (1851-1928), Charles Darwin (1809-1882), Samuel Huntington (1731-1796), and Roger Sherman (1721-1793).</abstract>
         <origination label="creator">
            <persname identifier="http://id.loc.gov/authorities/names/no2007123298"
                      relator="col"
                      rules="aacr"
                      source="naf">
               <part>Rabinowitz, Louis M. (Louis Mayer), 1887-1957</part>
            </persname>
         </origination>
    
      </did>
      <prefercite id="aspace_b8ff0a3b559b72b0d1860145a4708cb8">
         <head>Preferred Citation</head>
