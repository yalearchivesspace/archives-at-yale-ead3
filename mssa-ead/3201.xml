         <abstract id="aspace_a58a125baf7dec1328ea15e02963382a">The papers consist of correspondence, research materials, typescripts, and galley proofs for ten books written by Von Hagen relating to Central and South American history.</abstract>
         <origination label="Creator">
            <persname identifier="http://id.loc.gov/authorities/names/n80019587" source="naf">
               <part localtype="agent_person">Von Hagen, Victor Wolfgang, 1908-1985</part>
            </persname>
         </origination>
    
