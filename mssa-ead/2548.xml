                      rules="aacr"
                      source="naf">
               <part>Stern, Robert A. M., 1939-</part>
            </persname>
         </origination>
    
      </did>
      <odd id="aspace_03c391b238db774ad2217be3cda6a0b7">
         <head>General note</head>
         <p>Forms part of Yale Record Group 18-H (YRG 18-H), Audi-visual materials and memorabilia documenting the Yale School of Art and Architecture and its predecessors.</p>  
      </odd>
