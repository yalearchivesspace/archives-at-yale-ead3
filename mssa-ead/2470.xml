         </physdescstructured>
         <unitdatestructured unitdatetype="inclusive">
            <daterange>
               <fromdate standarddate="1930">1930</fromdate>
               <todate standarddate="1968">1968</todate>
            </daterange>
         </unitdatestructured>
         <abstract id="aspace_99be85e88f7d97bae91faff57e501dfa">The materials consist of photographs documenting the construction of Payne Whitney Gymnasium at Yale. Included are exterior and interior views, specifically photographs of the trophy and exercise rooms, pools, squash courts, and the indoor track.</abstract>
    
      </did>
      <odd id="aspace_61566697ad06bb6cc6630e8411591a48">
         <head>General note</head>
         <p>Forms part of Yale Record Group 46-B (YRG 46-B), Records and materials documenting individual Yale buildings, facilities, and grounds.</p>  
      </odd>
      <prefercite id="aspace_bbb526c3b34e723509a3650370fb3be8">
         <head>Preferred Citation</head>
         <p>Payne Whitney Gymnasium, Yale University, Photographs (RU 612). Manuscripts and Archives, Yale University Library.</p>  
      </prefercite>
      <accessrestrict id="aspace_cb6cbcc7715eaedcd0938046a49fe732">
         <head>Conditions Governing Access</head>
         <p>The materials are open for research.</p>  
      </accessrestrict>
      <arrangement id="aspace_ddb770e925337b5f08c53f90bf990182">
         <head>Arrangement</head>
         <p>The materials are arranged in two series: I. Construction Progress Photographs, 1930-1932. II. General Views, 1930-1968.</p>  
      </arrangement>
      <scopecontent id="aspace_ffde3691187179afc74d66b43d93f304">
         <head>Scope and Contents</head>
         <p>The materials consist of photographs documenting the construction of Payne Whitney Gymnasium at Yale. Included are exterior and interior views, specifically photographs of the trophy and exercise rooms, pools, squash courts, and the indoor track.</p>  
      </scopecontent>
