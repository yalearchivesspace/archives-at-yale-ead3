      <scopecontent id="aspace_489c5dd108bea1939ec5bc82bf6342c8">
         <head>Content Description</head>
         <p>Recordings of unreleased live chamber music performances by oboist Ronald Roseman.</p>
      </scopecontent>
      <userestrict id="aspace_a6d52795337ac427253ec433d2d5ab25">
