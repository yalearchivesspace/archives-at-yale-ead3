         <abstract id="aspace_ba5d0f1c96146c694936858405453c05">Letters by the American pianist Mary Van Nes concerning her experience as a student of Arthur Schnabel in Germany</abstract>
         <origination label="creator">
            <persname identifier="dts_bdb433194359a548a8bb82f864a32aa57c80c033" source="naf">
