                  <unittitle>Achillini, Claudio (1574-1640). Autograph letter, signed, Bologna, to an unidentified recipient</unittitle>
                  <unitdate unitdatetype="inclusive">1627 August 4</unitdate>
                  <physdesc id="aspace_c0addc2b16e13f0632e047aff64cf297">1 page, folio</physdesc>
                  <container containerid="39002088753539"
