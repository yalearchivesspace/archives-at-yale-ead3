      </prefercite>
      <bioghist id="aspace_edf350cb640651826784cb1551e4d43b">
         <head>Biographical / Historical</head>
         <p>Lucy Thompson, a full-blooded Klamath Indian woman, author of To the American Indian (Eureka, Cal., 1916).</p>
      </bioghist>
      <custodhist id="aspace_905adf29ed1cec71ef1cd5017393bf48">
         <head>Custodial History</head>
         <p>Purchased from Argonaut Book Shop on the Walter McClintock Memorial Fund, 1965.</p>
      </custodhist>
