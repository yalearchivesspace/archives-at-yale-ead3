               <part>Porter, Jane, 1776-1850</part>
            </persname>
         </origination>
         <origination label="creator">
            <persname source="local">
               <part>Porter, Jane, 1776-1850. ( Pastor's fire-side)</part>
            </persname>
         </origination>
         <origination label="creator">
            <persname rules="aacr" source="local">
               <part>Porter, Jane, 1776-1850. ( Thaddeus of Warsaw)</part>
            </persname>
         </origination>
    
