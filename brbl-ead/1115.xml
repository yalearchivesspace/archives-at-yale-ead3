                                localtype="box">1</container>
                  </did>
                  <scopecontent id="aspace_f498e31ac93ea169ec3e2af8685b0dc5">
                     <head>Scope and Contents</head>
                     <p>Salop <lb/> 4 p.; 21 x 16 <lb/> Pokes fun at Cholmeley's prospective <lb/> stay in London. <lb/> 357/11</p>
                  </scopecontent>
               </c>
            </c>
