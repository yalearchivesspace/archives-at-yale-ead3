                                id="aspace_1fe588056f0c110800615d87b335e9e8"
                                label="Mixed Materials"
                                localtype="box">1</container>
                  </did>
                  <scopecontent id="aspace_0473b27c75737a38e5db36a78a1739ef">
                     <head>Scope and Contents</head>
                     <p>3 p.; 21 x 16 cm. <lb/> Chides his friend for not answering <lb/> his letters; admits he misses <lb/> Cambridge and his college friends; <lb/> tells of his dislike of Salop and the <lb/> disagreeable nature of his neighbors. <lb/> 357/9</p>
                  </scopecontent>
               </c>
            </c>
