      <userestrict id="aspace_022cf7d9fe19a6de469e85e8b49e311f">
         <head>Conditions Governing Use</head>
         <p>The Nevada Legislature Records is the physical property of the Beinecke Rare Book and Manuscript Library, Yale University. Literary rights, including copyright, belong to the authors or their legal heirs and assigns. For further information, consult the appropriate curator.</p>  
      </userestrict>
      <prefercite id="aspace_d5e2c0f028c9bf6ed74a3f918d6f3dd7">
