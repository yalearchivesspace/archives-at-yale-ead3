      </acqinfo>
      <arrangement id="aspace_120047b3ce39ac083b48af244750242e">
         <head>Arrangement</head>
         <p>Images are roughly organized into groups, but the regions and topics documented in the collection are present throughout the entire photographic order book.</p>
      </arrangement>
      <prefercite id="aspace_ffbca629489532542c53057c98a18049">
