                     <p>17 x 21 cm. <lb/> On a fragment of a title-page removed <lb/> from a printed book. <lb/> d 1/288</p>
                  </scopecontent>
               </c>
            </c>
            <c id="ref31" level="subseries">
               <did>
                  <unittitle>REES, RICHARD</unittitle>
               </did>
