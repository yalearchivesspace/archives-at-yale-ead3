   <archdesc level="collection">
      <did>
         <unittitle>[Letters and documents concerning various members of the Arundell family].</unittitle>
         <unitid>OSBORN FB42</unitid>
         <repository>
            <corpname>
               <part>Beinecke Rare Book and Manuscript Library</part>
            </corpname>
         </repository>
         <langmaterial>
            <language langcode="eng">English</language>
         </langmaterial>
         <physdescstructured coverage="whole" physdescstructuredtype="spaceoccupied">
            <quantity>0.06</quantity>
            <unittype>Linear Feet</unittype>
         </physdescstructured>
         <physdesc localtype="container_summary">(1 volume)</physdesc>
         <unitdatestructured unitdatetype="inclusive">
            <daterange>
               <fromdate standarddate="1665">1665</fromdate>
               <todate standarddate="1680">1680</todate>
            </daterange>
         </unitdatestructured>
         <abstract id="aspace_ef1092459ae332f596cafbaed81e840b">Manuscripts, in multiple hands, of ten business letters and legal documents concerning members of the Arundel family. The collection incldues two bonds of payment; several money orders; and two letters from R. Arundel to Sir Robert Clayton, drawing Clayton's attention to a "young lady of a considerable fortune," asking for Clayton's assistance in marriage-making for Arundel's son, and explaining what he would be willing to settle upon the couple.</abstract>
         <origination label="creator">
            <famname identifier="http://id.loc.gov/authorities/subjects/sh2013002164"
                     source="naf">
               <part>Arundel family</part>
            </famname>
         </origination>
    
      </did>
