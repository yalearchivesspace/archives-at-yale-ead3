                             localtype="folder"
                             parent="aspace_e2a307d5d3b03694178870494f23d772">2</container>
               </did>
               <scopecontent id="aspace_f7343ed84fed9f67a26429368d281c4a">
                  <head>Scope and Contents</head>
                  <p>Approved by Baron Carondelet, Governor of Louisiana.</p>
               </scopecontent>
            </c>
            <c id="ref14" level="file">
               <did>
                  <unittitle>Moore, Alexander. Petition for a land grant. Manshaque, La.</unittitle>
                  <unitdate unitdatetype="inclusive">1794 Feb 25</unitdate>
                  <container containerid="39002094272185"
                             id="aspace_077fd540660090c3f13e8abc39f24793"
                             label="Mixed Materials"
                             localtype="box">1</container>
                  <container id="aspace_3f7834caae79dbf4b96b90dc04aec215"
                             localtype="folder"
                             parent="aspace_077fd540660090c3f13e8abc39f24793">3</container>
               </did>
               <scopecontent id="aspace_d58fc19e4c94cb0f3a9cc238ce558219">
                  <head>Scope and Contents</head>
                  <p>Endorsed by Francisco Rivas and approved by Baron Carondelet.</p>
               </scopecontent>
            </c>
            <c id="ref16" level="file">
               <did>
                  <unittitle>Gallagher, Jacinta. Petition for land grant. Natchez.</unittitle>
                  <unitdate unitdatetype="inclusive">1794 Mar 17</unitdate>
                  <container containerid="39002094272185"
                             id="aspace_92f6cbe08416e0515c8a447beb9452f7"
                             label="Mixed Materials"
                             localtype="box">1</container>
                  <container id="aspace_ed3166044ea4cd6dee78f5d74d1cba2c"
                             localtype="folder"
                             parent="aspace_92f6cbe08416e0515c8a447beb9452f7">4</container>
               </did>
               <scopecontent id="aspace_8ddb95695a7e7147aa126126611adb06">
                  <head>Scope and Contents</head>
                  <p>With favorable endorsement by Baron Carondelet.</p>
               </scopecontent>
            </c>
            <c id="ref18" level="file">
               <did>
                  <unittitle>Natchez (District, Province of Louisiana) Governor (Gayoso de Lemos). Regulations governing livestock. Natchez.</unittitle>
                  <unitdate unitdatetype="inclusive">1794 Sep 18</unitdate>
                  <container containerid="39002094272185"
                             id="aspace_ac4955a9d085263c6f07545a8c24952b"
                             label="Mixed Materials"
                             localtype="box">1</container>
                  <container id="aspace_217abd5b2517f54265bc2b2e23a8311b"
                             localtype="folder"
                             parent="aspace_ac4955a9d085263c6f07545a8c24952b">5</container>
               </did>
               <scopecontent id="aspace_e9207dd5f55de04b6d7e16246d79ef58">
                  <head>Scope and Contents</head>
                  <p>With this is sewn a decree of Oct 8, 1794 on repair of highways and bridges.</p>
               </scopecontent>
            </c>
            <c id="ref20" level="file">
               <did>
                  <unittitle>Natchez (District, Province of Louisiana) Governor (Gayoso de Lemos). Proclamation. Natchez.</unittitle>
                  <unitdate unitdatetype="inclusive">1797 Mar 29</unitdate>
                  <container containerid="39002094272185"
                             id="aspace_249149515a9685f82f712091f6c81668"
                             label="Mixed Materials"
                             localtype="box">1</container>
                  <container id="aspace_03a86479a3cec4f370564ca955bd44f0"
                             localtype="folder"
                             parent="aspace_249149515a9685f82f712091f6c81668">6</container>
               </did>
               <scopecontent id="aspace_2f7d2094be41fdaa891f1661dd34378a">
                  <head>Scope and Contents</head>
                  <p>Official seal affixed. Warns the inhabitants against political intrigue and assures them that the Spanish government will protect their rights.</p>
               </scopecontent>
            </c>
            <c id="ref22" level="file">
               <did>
                  <unittitle>Louisiana (Province) Governor. (Carondelet). Proclamation. New Orleans.</unittitle>
                  <unitdate unitdatetype="inclusive">1797 May 24</unitdate>
                  <container containerid="39002094272185"
                             id="aspace_c2b4ec66a95dc40448594ee1e087ac64"
                             label="Mixed Materials"
                             localtype="box">1</container>
                  <container id="aspace_cd52165f948e1732f36aa4f7cb951d6a"
                             localtype="folder"
                             parent="aspace_c2b4ec66a95dc40448594ee1e087ac64">7</container>
               </did>
               <scopecontent id="aspace_d684e773e1df0ef7d47b6a2bf5370a74">
                  <head>Scope and Contents</head>
                  <p>With offical seal. States that delay in marking boundary with U.S. and reinforcement of Walnut Hill is due to British threat against Louisiana. Mutilated, affecting a few words.</p>
               </scopecontent>
            </c>
            <c id="ref24" level="file">
               <did>
                  <unittitle>Natchez (District, Province of Louisiana) Governor (Gayoso de Lemos). Proclamation. Natchez.</unittitle>
                  <unitdate unitdatetype="inclusive">1797 Jun 14</unitdate>
                  <container containerid="39002094272185"
                             id="aspace_809ab659c4ea4ff64f47b30f3caa3b63"
                             label="Mixed Materials"
                             localtype="box">1</container>
                  <container id="aspace_79647d41dc4130c508fc14b10981a4bd"
                             localtype="folder"
                             parent="aspace_809ab659c4ea4ff64f47b30f3caa3b63">8</container>
               </did>
               <scopecontent id="aspace_f4971976751982fb1494e505d82e1969">
                  <head>Scope and Contents</head>
                  <p>Denies rumors of war between Spain and the U.S., and forbids public meetings.</p>
               </scopecontent>
            </c>
