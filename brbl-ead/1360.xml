            <c id="ref10" level="file">
               <did>
                  <unittitle>Dunbar, William. Expediente relative to the collection of a debt owed to the estate of E. Gallaudet by L. Pellerin. New Orleans.</unittitle>
                  <unitdate unitdatetype="inclusive">1792 Jul 23</unitdate>
                  <container containerid="39002094272185"
                             id="aspace_3bb083318c04bbfef445d57a7b039984"
