                     <datesingle standarddate="1802">1802</datesingle>
                  </unitdatestructured>
                  <container altrender="Paige 15"
                             id="aspace_aabbbe629f24b06bc0d3a9f907c70aca"
                             label="Mixed Materials"
                             localtype="Box">1</container>
