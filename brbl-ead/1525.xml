                             label="Mixed Materials"
                             localtype="box">2</container>
                  <container id="aspace_cc4d5ebce1b774b26135fedec0f73d11"
                             localtype="folder"
                             parent="aspace_e5aa2a8658b19403b984a892aad703a4">19</container>
               </did>
               <scopecontent id="aspace_6b1fdde6fe9a7e9ab2cbb664f3e847a2">
                  <head>Scope and Contents</head>
                  <p>A checklist of Jargon Books (1951-1960) with a letter on typed on it from Williams about Irving Layton, Arnold Ward, and Clarence John Laughlin.</p>
               </scopecontent>
            </c>
         </c>
         <c id="ref30" level="series">
            <did>
