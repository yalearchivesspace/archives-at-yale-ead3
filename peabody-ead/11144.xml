         <abstract id="aspace_463bb690d07171cf55d0a1f5b7981432">The archives of Thomas W. Amsden including maps, field notes and photographs. These focus on his 1947 Yale dissertation, "Stratigraphy and paleontology of the Brownsport Silurian of western Tennessee."</abstract>
         <origination label="Creator">
            <persname source="local_peabody">
               <part localtype="agent_person">Amsden, Thomas William</part>
            </persname>
         </origination>
      </did>
