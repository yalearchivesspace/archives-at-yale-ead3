                  <unitdate unitdatetype="inclusive">1905 May 23</unitdate>
                  <container altrender="archive legal tall"
                             containerid="39002010858000"
                             id="aspace_dedac75bd0476fb36672b193d4221ee4"
                             label="Mixed Materials"
                             localtype="box">1</container>
                  <container id="aspace_8ba504d6a67dea29085cfe7ad279d9c1"
                             localtype="folder"
