            id="aspace_2f2ccd3c5bb04fb29907ad9e7f7a32fa"
            level="item">
            <did>
               <unittitle>Carr, Norman, M.D., <title>
                     <part>Reliable birth control preparations</part>
                  </title>. Chicago: Lanteen Laboratories, Inc.</unittitle>
               <unitdatestructured altrender="circa 1930-1939"
                                   label="creation"
                                   unitdatetype="inclusive">
                  <daterange>
                     <fromdate standarddate="1930">1930</fromdate>
                     <todate standarddate="1939">1939</todate>
                  </daterange>
