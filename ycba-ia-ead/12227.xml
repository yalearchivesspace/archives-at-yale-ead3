                                      label="creation"
                                      unitdatetype="inclusive">
                     <datesingle standarddate="1908-01-08">1908 January 8</datesingle>
                  </unitdatestructured>
                  <physdesc id="aspace_e118b496740646e9baf35c8535e6e748">1 folded sheet + 1 envelope</physdesc>
