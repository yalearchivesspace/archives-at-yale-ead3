               </did>
               <scopecontent id="aspace_6e15b24edbc56962dcab67499955e195">
                  <head>Scope and Contents</head>
                  <p>Southall writes to tell Hodson he will not need the Mirror or Beauty at the Fountain for an exhibition he will be a part of in London but says he will send Hodson a private viewing ticket.</p>
               </scopecontent>
               <controlaccess>
                  <genreform identifier="http://vocab.getty.edu/aat/300026877" source="aat">
                     <part localtype="genre_form">Correspondence </part>
                  </genreform>
               </controlaccess>
            </c>
            <c altrender="/repositories/3/archival_objects/3359438"
               id="aspace_4be987fc934542da3541a88d046023fd"
               level="item">
               <did>
                  <unittitle>Joseph Southall letter to Laurence Hodson</unittitle>
                  <unitdatestructured altrender="1907 December 31"
                                      label="creation"
                                      unitdatetype="inclusive">
                     <datesingle standarddate="1907-12-31">1907 December 31</datesingle>
                  </unitdatestructured>
                  <physdesc id="aspace_99114374df8da6b003b3c3d2b058eb66">1 folded sheet + 1 envelope + 1 photograph</physdesc>
                  <container altrender="/repositories/3/top_containers/379023"
