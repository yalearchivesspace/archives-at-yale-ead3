                                      unitdatetype="inclusive">
                     <datesingle standarddate="1910-02-20">1910 February 20</datesingle>
                  </unitdatestructured>
                  <physdesc id="aspace_5a962f5b82d31fa40dfb693d8f3ed3f3">1 folded sheet + 1 envelope</physdesc>
