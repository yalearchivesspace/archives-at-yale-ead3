         <abstract id="aspace_e0a94e8ad4041ad1aaffc2de16913816">This collection contains bookplates by the Dutch artist Wim Zwiers. Many are signed proofs or numbered prints.</abstract>
         <origination label="creator">
            <persname source="local">
               <part>Zwiers, Wim, 1922-</part>
            </persname>
         </origination>
    
