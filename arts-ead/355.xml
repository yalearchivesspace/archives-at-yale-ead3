            <arrangement id="aspace_0080ecaeb634073aeda127ebb6160629">
               <head>Arrangement</head>
               <p>Categories are based on the country or region of origin for the artwork, not the publisher.</p>
            </arrangement>
            <scopecontent id="aspace_c5d2682c803998c8a318bada5debfedf">
