      <dsc>
         <c id="ref9" level="series">
            <did>
               <unittitle>Coats of Arms</unittitle>
               <unitid>Series I</unitid>
            </did>
            <arrangement id="aspace_ca0c69ee3cddc0bbe55abec35b55dfa4">
               <head>Arrangement</head>
               <p>The coats of arms are arranged alphabetically by surname.</p>
            </arrangement>
            <scopecontent id="aspace_9af156d10515610b702d222755640430">
               <head>Scope and Contents</head>
               <p>This series contains black-and-white printed illustrations of coats of arms, mounted on individual sheets of paper and labeled with family names. A note included with the materials states that the German crests were used to aid in the identification of bookplates (see Folder 1).</p>
            </scopecontent>
